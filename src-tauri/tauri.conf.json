{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "distDir": "../src",
    "devPath": "../src",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "Genomed VPN",
    "version": "1.1.1"
  },
  "tauri": {
    "allowlist": {
      "shell": { "open": true }
    },
    "bundle": {
      "active": true,
      "identifier": "ru.genomed.vpn",
      "targets": "all",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.ico"
      ]
    },
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'"
    },
    "systemTray": {
      "iconPath": "icons/tray.png",
      "iconAsTemplate": false
    },
    "windows": [
      {
        "title": "Genomed VPN",
        "width": 340,
        "height": 360,
        "resizable": false,
        "visible": true
      }
    ]
  }
}
